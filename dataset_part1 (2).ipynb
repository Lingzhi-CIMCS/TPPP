import random
import math
import numpy as np
import pickle
from pathlib import Path

N_SAMPLES = 10000
SEQ_LEN = 15
SEED = 19850705
DATA_DIR = Path("driving_data")

DT = 0.1
ACCEL_FACTOR = 5
L = 1.0
MAX_STEER_DEG = 45
MAX_V = 10.0
MAX_STEER_CHANGE = 1.5
MAX_THR_CHANGE = 1
MIN_OBS_DIST = 2
OB_FIELD_RANGE = 20
MAX_OBS_COUNT = 150
OBS_PERSIST_DIST = 30.0
SPAWN_ATTEMPTS = 10
TERMINATE_X_THRESH = 50.0
TERMINATE_COLL_DIST = 0.1

def set_seed(seed=42):
    np.random.seed(seed)
    random.seed(seed)

def angle_wrap(a):
    return (a + np.pi) % (2*np.pi) - np.pi

def euclidean(p, q):
    return math.hypot(p[0]-q[0], p[1]-q[1])

def generate_obstacles(pos, theta, obs_set):
    if len(obs_set) >= MAX_OBS_COUNT:
        return
    new, tries = 0, 0
    while new < SPAWN_ATTEMPTS and tries < SPAWN_ATTEMPTS*5:
        ang = np.random.uniform(-np.pi/2, np.pi/2)
        rad = np.random.uniform(MIN_OBS_DIST, OB_FIELD_RANGE)
        ox, oy = pos[0] + rad*math.cos(theta+ang), pos[1] + rad*math.sin(theta+ang)
        pt = (round(ox,1), round(oy,1))
        if all(euclidean(pt, e) > 1 for e in obs_set) and euclidean(pt, pos) > MIN_OBS_DIST:
            obs_set.add(pt)
            new += 1
        tries += 1
    for o in list(obs_set):
        if euclidean(pos, o) > OBS_PERSIST_DIST:
            obs_set.remove(o)

def get_perception(pos, theta, obs_set):
    d_front = d_left = d_right = OB_FIELD_RANGE
    for ox, oy in obs_set:
        r = euclidean((ox,oy), pos)
        ang = angle_wrap(math.atan2(oy-pos[1], ox-pos[0]) - theta)
        if -np.pi/6 <= ang <= np.pi/6:
            d_front = min(d_front, r)
        elif np.pi/3 <= ang <= 2*np.pi/3:
            d_left = min(d_left, r)
        elif -2*np.pi/3 <= ang <= -np.pi/3:
            d_right = min(d_right, r)
    return d_front, d_left, d_right

def generate_dataset(n_samples=N_SAMPLES, seq_len=SEQ_LEN):
    X_all, Y_all = [], []
    for i in range(n_samples):
        if i % 1000 == 0:
            print(f"Generating sample {i}/{n_samples}")
        x = y = theta = v = 0.0
        prev_thr = prev_st = 0.0
        obs_set = set()
        seq_in, seq_out = [], []
        for step in range(seq_len):
            generate_obstacles((x,y), theta, obs_set)
            d_f, d_l, d_r = get_perception((x,y), theta, obs_set)
            desired_theta = 0.0
            if d_f < 1.0:
                raw_st = -1.0 if d_l > d_r else 1.0
            elif d_f < 5.0:
                raw_st = np.clip((d_r-d_l)/5.0, -1, 1) + 0.3*angle_wrap(desired_theta-theta)
            else:
                raw_st = 0.5*angle_wrap(desired_theta-theta)
            raw_thr = 1.0 if d_f > 5.0 else max(0.2, d_f/5.0)
            d_thr = np.clip(raw_thr - prev_thr, -MAX_THR_CHANGE*DT, MAX_THR_CHANGE*DT)
            thr = prev_thr + d_thr
            d_st = np.clip(raw_st - prev_st, -MAX_STEER_CHANGE*DT, MAX_STEER_CHANGE*DT)
            st = np.clip(prev_st + d_st, -1, 1)
            prev_thr, prev_st = thr, st
            seq_in.append([v, d_f, d_l, d_r])
            seq_out.append([st, thr])
            v += (thr - 0.2) * ACCEL_FACTOR * DT
            v = np.clip(v, 0, MAX_V)
            delta = st * math.radians(MAX_STEER_DEG)
            x += v * math.cos(theta) * DT
            y += v * math.sin(theta) * DT
            theta = angle_wrap(theta + (v/L)*math.tan(delta)*DT)
            if x > TERMINATE_X_THRESH or d_f < TERMINATE_COLL_DIST:
                while len(seq_in) < seq_len:
                    seq_in.append(seq_in[-1])
                    seq_out.append(seq_out[-1])
                break
        X_all.append(seq_in)
        Y_all.append(seq_out)
    return np.asarray(X_all, np.float32), np.asarray(Y_all, np.float32)

if __name__ == "__main__":
    set_seed(SEED)
    DATA_DIR.mkdir(exist_ok=True, parents=True)
    print(f"Generating dataset with {N_SAMPLES} samples...")
    print(f"Sequence length: {SEQ_LEN}")
    print(f"Random seed: {SEED}")
    X, Y = generate_dataset()
    split = int(0.8 * N_SAMPLES)
    X_train, Y_train = X[:split], Y[:split]
    X_test, Y_test = X[split:], Y[split:]
    print(f"\nDataset generated:")
    print(f"  Full dataset shape - X: {X.shape}, Y: {Y.shape}")
    print(f"  Train split - X: {X_train.shape}, Y: {Y_train.shape}")
    print(f"  Test split - X: {X_test.shape}, Y: {Y_test.shape}")
    np.save(DATA_DIR / "X_train.npy", X_train)
    np.save(DATA_DIR / "Y_train.npy", Y_train)
    np.save(DATA_DIR / "X_test.npy", X_test)
    np.save(DATA_DIR / "Y_test.npy", Y_test)
    np.save(DATA_DIR / "X_full.npy", X)
    np.save(DATA_DIR / "Y_full.npy", Y)
    with open(DATA_DIR / "dataset.pkl", "wb") as f:
        pickle.dump({
            'X_train': X_train,
            'Y_train': Y_train,
            'X_test': X_test,
            'Y_test': Y_test,
            'X_full': X,
            'Y_full': Y,
            'metadata': {
                'n_samples': N_SAMPLES,
                'seq_len': SEQ_LEN,
                'train_split': split,
                'seed': SEED,
                'input_features': ['velocity', 'd_front', 'd_left', 'd_right'],
                'output_features': ['steering', 'throttle'],
                'dt': DT,
                'max_v': MAX_V,
                'max_steer_deg': MAX_STEER_DEG
            }
        }, f)
    print(f"\nDataset saved to {DATA_DIR}/")
    print("Files created:")
    print("  - X_train.npy, Y_train.npy (for training)")
    print("  - X_test.npy, Y_test.npy (for testing)")
    print("  - X_full.npy, Y_full.npy (complete dataset)")
    print("  - dataset.pkl (with metadata)")
    print("\nDataset Statistics:")
    print(f"Input features:")
    for i, name in enumerate(['Velocity', 'D_front', 'D_left', 'D_right']):
        print(f"  {name}: min={X[:,:,i].min():.2f}, max={X[:,:,i].max():.2f}, mean={X[:,:,i].mean():.2f}, std={X[:,:,i].std():.2f}")
    print(f"Output features:")
    for i, name in enumerate(['Steering', 'Throttle']):
        print(f"  {name}: min={Y[:,:,i].min():.2f}, max={Y[:,:,i].max():.2f}, mean={Y[:,:,i].mean():.2f}, std={Y[:,:,i].std():.2f}")
