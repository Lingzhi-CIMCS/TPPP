import numpy as np
import matplotlib.pyplot as plt
import random
import math
from pathlib import Path
import csv

DATA_DIR = Path("driving_data")
SAVE_DIR = Path("figs_Ackermann kinematics model_svd_both_weights")
SAVE_DIR.mkdir(exist_ok=True, parents=True)

X_train = np.load(DATA_DIR / "X_train.npy")
Y_train = np.load(DATA_DIR / "Y_train.npy")
X_test  = np.load(DATA_DIR / "X_test.npy")
Y_test  = np.load(DATA_DIR / "Y_test.npy")

print(f"Data loaded: Train {X_train.shape}, Test {X_test.shape}")

DT               = 0.1
ACCEL_FACTOR     = 5
L                = 1.0
MAX_STEER_DEG    = 45
MAX_V            = 10.0
MIN_OBS_DIST     = 2
OB_FIELD_RANGE   = 20
MAX_OBS_COUNT    = 150
OBS_PERSIST_DIST = 30.0
SPAWN_ATTEMPTS   = 10

COLLISION_RADIUS = 0.02
NEAR_MISS_RADIUS = 0.2

def angle_wrap(a: float) -> float:
    return (a + np.pi) % (2*np.pi) - np.pi

def euclidean(p, q) -> float:
    return math.hypot(p[0]-q[0], p[1]-q[1])

def generate_obstacles(pos, theta, obs_set: set):
    if len(obs_set) >= MAX_OBS_COUNT:
        return
    new, tries = 0, 0
    while new < SPAWN_ATTEMPTS and tries < SPAWN_ATTEMPTS*5:
        ang = np.random.uniform(-np.pi/2, np.pi/2)
        rad = np.random.uniform(MIN_OBS_DIST, OB_FIELD_RANGE)
        ox  = pos[0] + rad*math.cos(theta + ang)
        oy  = pos[1] + rad*math.sin(theta + ang)
        pt  = (round(ox, 1), round(oy, 1))
        if all(euclidean(pt, e) > 1 for e in obs_set) and euclidean(pt, pos) > MIN_OBS_DIST:
            obs_set.add(pt)
            new += 1
        tries += 1
    for o in list(obs_set):
        if euclidean(pos, o) > OBS_PERSIST_DIST:
            obs_set.remove(o)

def rollout_with_obstacles(ctrl_seq, seed: int = 999):
    rng_state = np.random.get_state()
    random_state = random.getstate()
    np.random.seed(seed)
    random.seed(seed)
    x = y = theta = v = 0.0
    v = 5.0
    xs, ys = [x], [y]
    obs_set, obs_union = set(), set()
    for st, thr in ctrl_seq:
        generate_obstacles((x, y), theta, obs_set)
        obs_union |= obs_set
        v += (thr - 0.2) * ACCEL_FACTOR * DT
        v = float(np.clip(v, 0, MAX_V))
        delta = st * math.radians(MAX_STEER_DEG)
        x += v * math.cos(theta) * DT
        y += v * math.sin(theta) * DT
        theta = angle_wrap(theta + (v / L) * math.tan(delta) * DT)
        xs.append(x)
        ys.append(y)
    np.random.set_state(rng_state)
    random.setstate(random_state)
    return xs, ys, obs_union

def min_distances_to_obstacles(xs, ys, obstacles):
    if not obstacles:
        return np.full(len(xs), np.inf)
    obs = np.array(list(obstacles), dtype=float)
    px  = np.array(xs)[:, None]
    py  = np.array(ys)[:, None]
    dx  = px - obs[None, :, 0]
    dy  = py - obs[None, :, 1]
    d   = np.hypot(dx, dy)
    return d.min(axis=1)

def compute_obstacle_metrics(ctrl_seq, seed=999,
                             collision_radius=COLLISION_RADIUS,
                             near_miss_radius=NEAR_MISS_RADIUS):
    xs, ys, obs_set = rollout_with_obstacles(ctrl_seq, seed=seed)
    dists = min_distances_to_obstacles(xs, ys, obs_set)
    collided = bool(np.any(dists <= collision_radius))
    first_collision_step = int(np.where(dists <= collision_radius)[0][0]) if collided else -1
    t_first_collision = first_collision_step * DT if collided else -1.0
    min_dist = float(np.min(dists))
    near_miss_count = int(np.sum((dists > collision_radius) & (dists <= near_miss_radius)))
    path_len = float(np.sum(np.hypot(np.diff(xs), np.diff(ys))))
    return {
        "collided": collided,
        "first_collision_step": first_collision_step,
        "t_first_collision": t_first_collision,
        "min_distance": min_dist,
        "near_miss_count": near_miss_count,
        "path_length": path_len,
        "steps": len(xs),
        "obstacle_count": len(obs_set),
        "seed": seed,
    }, (xs, ys, obs_set, dists)

def evaluate_success_rate(Y_data,
                          seed_base=2025,
                          limit=None,
                          collision_radius=COLLISION_RADIUS,
                          near_miss_radius=NEAR_MISS_RADIUS,
                          save_csv=True):
    n = len(Y_data) if limit is None else min(limit, len(Y_data))
    results = []
    min_dists = []
    success = 0
    for i in range(n):
        seed = seed_base + i
        metrics, _ = compute_obstacle_metrics(Y_data[i],
                                              seed=seed,
                                              collision_radius=collision_radius,
                                              near_miss_radius=near_miss_radius)
        results.append({"index": i, **metrics})
        min_dists.append(metrics["min_distance"])
        if not metrics["collided"]:
            success += 1
    success_rate = success / n if n > 0 else 0.0
    if save_csv:
        csv_path = SAVE_DIR / "obstacle_avoidance_metrics.csv"
        with open(csv_path, "w", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=list(results[0].keys()) if results else ["index"])
            writer.writeheader()
            for row in results:
                writer.writerow(row)
        print(f"Per-sample metrics saved: {csv_path}")
    summary = {
        "samples": n,
        "success": success,
        "fail": n - success,
        "success_rate": success_rate,
        "mean_min_distance": float(np.mean(min_dists)) if n else float("nan"),
        "median_min_distance": float(np.median(min_dists)) if n else float("nan"),
    }
    return summary, results, np.array(min_dists)

def plot_trajectory_with_obstacles(Y_true, Y_pred=None, sample_idx=0, seed=987,
                                   title_suffix="", save_name=None):
    xs_true, ys_true, obs_set = rollout_with_obstacles(Y_true, seed=seed)
    dists_true = min_distances_to_obstacles(xs_true, ys_true, obs_set)
    collided_true = np.any(dists_true <= COLLISION_RADIUS)
    min_dist_true = np.min(dists_true)
    fig = plt.figure(figsize=(5.8, 5.2))
    plt.plot(xs_true, ys_true, lw=2,
             label=f"Ground Truth ({'Collision' if collided_true else 'Safe'}, min dist={min_dist_true:.2f} m)")
    if Y_pred is not None:
        xs_pred, ys_pred, _ = rollout_with_obstacles(Y_pred, seed=seed)
        dists_pred = min_distances_to_obstacles(xs_pred, ys_pred, obs_set)
        collided_pred = np.any(dists_pred <= COLLISION_RADIUS)
        min_dist_pred = np.min(dists_pred)
        plt.plot(xs_pred, ys_pred, "--", lw=2,
                 label=f"Prediction ({'Collision' if collided_pred else 'Safe'}, min dist={min_dist_pred:.2f} m)")
    if obs_set:
        ox, oy = zip(*obs_set)
        plt.scatter(ox, oy, c="red", marker="x", s=25, label="Obstacles")
    plt.title(f"Trajectory with Obstacles{title_suffix}")
    plt.xlabel("X (m)")
    plt.ylabel("Y (m)")
    plt.axis("equal")
    plt.grid(True)
    plt.legend()
    if save_name and SAVE_DIR:
        plt.savefig(SAVE_DIR / f"{save_name}.png", dpi=120, bbox_inches="tight")
    plt.show()
    return fig

def plot_3d_trajectory(Y_true, Y_pred=None, sample_idx=0, seed=987, save_name=None):
    try:
        from mpl_toolkits.mplot3d import Axes3D
        xs_true, ys_true, obs_set = rollout_with_obstacles(Y_true, seed=seed)
        fig = plt.figure(figsize=(6, 5))
        ax3d = fig.add_subplot(111, projection="3d")
        t_axis = np.arange(len(xs_true)) * DT
        ax3d.plot(xs_true, ys_true, t_axis, lw=2, label="Ground Truth")
        if Y_pred is not None:
            xs_pred, ys_pred, _ = rollout_with_obstacles(Y_pred, seed=seed)
            ax3d.plot(xs_pred, ys_pred, t_axis[:len(xs_pred)], "--", lw=2, label="Prediction")
        if obs_set:
            ox, oy = zip(*obs_set)
            ax3d.scatter(ox, oy, [t_axis[-1]]*len(ox), c="red", marker="x", s=20, label="Obstacles")
        ax3d.set_xlabel("X (m)")
        ax3d.set_ylabel("Y (m)")
        ax3d.set_zlabel("Time (s)")
        ax3d.set_title("3-D Trajectory with Obstacles")
        ax3d.legend()
        if save_name and SAVE_DIR:
            plt.savefig(SAVE_DIR / f"{save_name}.png", dpi=120, bbox_inches="tight")
        plt.show()
        return fig
    except Exception as e:
        print("3-D plot skipped:", e)
        return None

def plot_multiple_trajectories_grid(X_data, Y_data, n_samples=4, seed_base=42):
    fig, axes = plt.subplots(2, 2, figsize=(12, 10))
    axes = axes.flatten()
    indices = np.random.choice(len(Y_data), min(n_samples, len(Y_data)), replace=False)
    for i, idx in enumerate(indices):
        if i >= len(axes):
            break
        ax = axes[i]
        Y_sample = Y_data[idx]
        xs, ys, obstacles = rollout_with_obstacles(Y_sample, seed=seed_base + i)
        dists = min_distances_to_obstacles(xs, ys, obstacles)
        collided = np.any(dists <= COLLISION_RADIUS)
        min_dist = np.min(dists)
        if obstacles:
            ox, oy = zip(*obstacles)
            ax.scatter(ox, oy, c='red', marker='x', s=30, alpha=0.6, label="Obstacles")
        ax.plot(xs, ys, 'b-', linewidth=2,
                label=f"{'Collision' if collided else 'Safe'}, min dist={min_dist:.2f} m")
        ax.scatter(xs[0], ys[0], c='green', s=100, marker='o', zorder=10, label="Start")
        ax.scatter(xs[-1], ys[-1], c='orange', s=100, marker='s', zorder=10, label="End")
        ax.set_xlabel('X (m)')
        ax.set_ylabel('Y (m)')
        ax.set_title(f'Sample {idx}')
        ax.grid(True, alpha=0.3)
        ax.axis('equal')
        ax.legend()
    plt.suptitle('Vehicle Trajectories in Obstacle Environment')
    plt.tight_layout()
    plt.savefig(SAVE_DIR / "multiple_trajectories.png", dpi=120, bbox_inches="tight")
    plt.show()

def plot_metrics_summary(min_dists: np.ndarray, summary: dict):
    fig, ax = plt.subplots(1, 2, figsize=(12, 4))
    finite_d = min_dists[np.isfinite(min_dists)]
    ax[0].hist(finite_d, bins=30)
    ax[0].axvline(COLLISION_RADIUS, linestyle='--', label=f"Collision radius ({COLLISION_RADIUS} m)")
    ax[0].axvline(NEAR_MISS_RADIUS, linestyle='--', label=f"Near-miss radius ({NEAR_MISS_RADIUS} m)")
    ax[0].set_title("Distribution of Minimum Clearances")
    ax[0].set_xlabel("Minimum clearance (m)")
    ax[0].set_ylabel("Count")
    ax[0].legend()
    ax[1].bar(["Success (Safe)", "Failure (Collision)"], [summary["success"], summary["fail"]])
    ax[1].set_title(f"Obstacle-Avoidance Success Rate: {summary['success_rate']*100:.2f}%")
    ax[1].set_ylabel("Number of samples")
    plt.tight_layout()
    plt.savefig(SAVE_DIR / "obstacle_avoidance_summary.png", dpi=120, bbox_inches="tight")
    plt.show()

if __name__ == "__main__":
    print("Visualizing trajectories with obstacles...")
    print("=" * 50)
    idx = np.random.randint(0, X_test.shape[0])
    print(f"Selected test sample index: {idx}")
    Y_true = Y_test[idx]
    print("\n1) 2D Trajectory with obstacles:")
    plot_trajectory_with_obstacles(
        Y_true,
        sample_idx=idx,
        seed=987,
        title_suffix=f" (test idx {idx})",
        save_name="trajectory_with_obstacles"
    )
    print("\n2) 3D Trajectory with obstacles:")
    plot_3d_trajectory(
        Y_true,
        sample_idx=idx,
        seed=987,
        save_name="trajectory_3d_obstacles"
    )
    print("\n3) Multiple trajectory visualization:")
    plot_multiple_trajectories_grid(X_test, Y_test, n_samples=4)
    print("\n4) Dataset-level obstacle-avoidance evaluation:")
    summary, results, min_dists = evaluate_success_rate(
        Y_test,
        seed_base=13579,
        limit=None,
        collision_radius=COLLISION_RADIUS,
        near_miss_radius=NEAR_MISS_RADIUS,
        save_csv=True
    )
    print("\n==== Obstacle-Avoidance Success & Metrics ====")
    print(f"Total samples: {summary['samples']}")
    print(f"Success (no collision): {summary['success']}")
    print(f"Failure (collision): {summary['fail']}")
    print(f"Success rate: {summary['success_rate']*100:.2f}%")
    print(f"Mean min distance: {summary['mean_min_distance']:.3f} m")
    print(f"Median min distance: {summary['median_min_distance']:.3f} m")
    plot_metrics_summary(min_dists, summary)
    print("\n5) To visualize model predictions:")
    print("   - Train your model and generate predicted control sequences")
    print("   - Call plot_trajectory_with_obstacles(Y_true, Y_pred=predicted_seq)")
    print("\nVisualization + metrics complete!")
    print(f"Figures and CSV saved to {SAVE_DIR}/")
